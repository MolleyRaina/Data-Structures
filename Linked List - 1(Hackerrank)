#include <stdio.h>
#include <stdlib.h>
struct Node {
    int data;
    struct Node* next;
};
struct Node *head = NULL;
struct Node* createNode(int data) {
    struct Node* temp = (struct Node*) malloc(sizeof(struct Node));
    temp->data = data;
    temp->next = NULL;
    return temp;
}
void insertInBeg(int data) {
    struct Node* newNode = createNode(data);
    newNode->next = head;
    head = newNode;
}
void insertAtEnd(int data) {
    struct Node* newNode = createNode(data);
    if (head == NULL) {
        head = newNode;
    } else {
        struct Node* temp = head;
        while (temp->next != NULL) {
            temp = temp->next;
        }
        temp->next = newNode;
    }
}
void insertAtAnyPos(int data, int pos) {
    if (pos == 1) {
        insertInBeg(data);
    } else {
        struct Node* temp = head;
        int i = 1;
        while (temp != NULL) {
            if (i == pos - 1) {
                break;
            }
            temp = temp->next;
            i++;
        }
        if (temp != NULL) {
            struct Node* newNode = createNode(data);
            newNode->next = temp->next;
            temp->next = newNode;
        }
    }
}
void deleteFromAnyPos(int pos) {
    if (head == NULL) {
        return;
    } else if (pos == 1) {
        struct Node* temp = head;
        head = head->next;
        free(temp);
    } else {
        struct Node* temp = head;
        int i = 1;
        while (temp != NULL) {
            if (i == pos - 1) {
                break;
            }
            temp = temp->next;
            i++;
        }
        if (temp != NULL && temp->next != NULL) {
            struct Node* del = temp->next;
            temp->next = temp->next->next;
            free(del);
        }
    }
}
void displayList() {
    struct Node* temp = head;
    while (temp != NULL) {
        printf("%d ", temp->data);
        temp = temp->next;
    }
    printf("\n");
}
int main() {
    int n, val, pos, data;
    if (scanf("%d", &n) != 1) return 0;
    for (int i = 0; i < n; i++) {
        scanf("%d", &val);
        insertAtEnd(val);
    }
    scanf("%d", &data);
    insertInBeg(data);
    scanf("%d", &pos);
    deleteFromAnyPos(pos);
    scanf("%d", &data);
    insertAtEnd(data);
    scanf("%d %d", &pos, &data);
    insertAtAnyPos(data, pos);
    displayList();
    return 0;
}
