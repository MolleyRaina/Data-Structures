#include <stdio.h>
#include <stdlib.h>
struct Node {
    int data;
    struct Node* next;
};
struct Node* head = NULL;
struct Node* createNode(int data) {
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));
    temp->data = data;
    temp->next = NULL;
    return temp;
}
void insertAtEnd(int data) {
    struct Node* newNode = createNode(data);
    if (head == NULL) {
        head = newNode;
    }
    else {
        struct Node* temp = head;
        while (temp->next != NULL) {
            temp = temp->next;
        }
        temp->next = newNode;
    }
}
struct Node* reverse(struct Node* node) {
    struct Node *prev = NULL, *curr = node, *next = NULL;
    while (curr != NULL) {
        next = curr->next;
        curr->next = prev;
        prev = curr;
        curr = next;
    }
    return prev;
}
int main() {
    int n, val;
    if (scanf("%d", &n) != 1) return 0;
    int arr[100];
    for (int i = 0; i < n; i++) {
        scanf("%d", &val);
        arr[i] = val;
        insertAtEnd(val);
    }
    head = reverse(head);
    int isPalindrome = 1;
    struct Node* temp = head;
    for (int i = 0; i < n; i++) {
        if (temp->data != arr[i]) {
            isPalindrome = 0;
        }
        temp = temp->next;
    }
    if (isPalindrome) {
    printf("Palindrome : ");
    }
    else {
        printf("Not Palindrome : ");
    }
    temp = head;
    while (temp != NULL) {
        printf("%d", temp->data);
        if (temp->next != NULL) {
            printf(" ");
        }
        temp = temp->next;
    }
    printf("\n");
    return 0;
}
